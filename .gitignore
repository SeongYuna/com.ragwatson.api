# =========================================================
# 1. 비밀정보 / 자격증명 (가장 중요)
# =========================================================
# 환경변수 파일 (DATABASE_URL, API 키 등)
.env
.env.*
!.env.example
!.env.sample
!.env.template

# 자격증명 / 키 파일
*.pem
*.key
*.crt
*.p12
*.pfx
*.jks
*.keystore
credentials.json
secrets.json
service-account*.json
*-credentials.json

# 클라우드 / CLI 설정
.aws/
.gcloud/
.azure/
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example

# =========================================================
# 2. Python (FastAPI 백엔드)
# =========================================================
__pycache__/
*.py[cod]
*$py.class
*.so

# 학습된 모델 아티팩트 (레포에 커밋하지 않음)
*.pkl
*.pt

# 패키징 / 빌드
build/
dist/
*.egg-info/
*.egg
.eggs/
pip-wheel-metadata/

# 가상환경
.venv/
venv/
env/
ENV/
.python-version

# 테스트 / 커버리지
